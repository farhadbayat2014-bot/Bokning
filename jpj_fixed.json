{
  "name": "SMS Job Booking med OK-svar",
  "nodes": [
    {
      "id": "twilio-trigger",
      "name": "Twilio Trigger (Lyssna på svar)",
      "type": "n8n-nodes-base.twilioTrigger",
      "position": [250, 300],
      "parameters": {
        "resource": "sms"
      }
    },
    {
      "id": "check-ok",
      "name": "Tolka OK-svar",
      "type": "n8n-nodes-base.if",
      "position": [450, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false
          },
          "conditions": [
            {
              "id": "f23c0ac5-ae2d-4473-991a-12323c44dab9",
              "leftValue": "={{ $json[\"Body\"] }}",
              "rightValue": "OK",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ],
          "combinator": "or"
        }
      }
    },
    {
      "id": "google-sheets",
      "name": "Registrera bokning i Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "position": [650, 250],
      "parameters": {
        "operation": "append",
        "sheetId": {
          "__rl": true,
          "value": "1a2b3c4d5e6f7g8h9i0j",
          "mode": "id"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Telefon": "={{ $json[\"From\"] }}",
            "Svar": "={{ $json[\"Body\"] }}",
            "Tid": "={{ $now.toISOString() }}",
            "Status": "Bokad"
          }
        }
      }
    },
    {
      "id": "send-confirmation",
      "name": "Skicka bekräftelse",
      "type": "n8n-nodes-base.twilio",
      "position": [850, 250],
      "parameters": {
        "resource": "sms",
        "operation": "send",
        "from": {
          "__rl": true,
          "value": "+46701234567",
          "mode": "id"
        },
        "to": "={{ $json[\"From\"] }}",
        "message": "Tack! Du är bokad till jobbet. Vi återkommer om detaljer."
      }
    }
  ],
  "connections": {
    "twilio-trigger": {
      "main": [
        [
          {
            "node": "check-ok",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-ok": {
      "main": [
        [
          {
            "node": "google-sheets",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "send-confirmation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "google-sheets": {
      "main": [
        [
          {
            "node": "send-confirmation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
